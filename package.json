{
  "name": "@nabla/vite-plugin-eslint",
  "description": "Plugs ESLint into Vite dev server",
  "version": "3.0.0",
  "license": "MIT",
  "author": "Arnaud Barré (https://github.com/ArnaudBarre)",
  "type": "module",
  "main": "src/index.cjs",
  "types": "src/index.d.ts",
  "module": "src/index.mjs",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "require": "./src/index.cjs",
      "import": "./src/index.mjs"
    }
  },
  "files": [
    "src"
  ],
  "repository": "github:nabla/vite-plugin-eslint",
  "keywords": [
    "vite",
    "eslint",
    "vite-plugin"
  ],
  "scripts": {
    "prettier": "prettier --write '**/*.{js,cjs,mjs,ts,json,md,yml}'"
  },
  "dependencies": {
    "@types/eslint": "*",
    "chalk": "^4",
    "debug": "^4"
  },
  "peerDependencies": {
    "eslint": "^9 || ^10",
    "vite": "^4 || ^5 || ^6 || ^7"
  },
  "devDependencies": {
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "vite": "^7.3.1"
  }
}
